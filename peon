#!/usr/bin/env python3
"""
peon - pipe any command through this and get notified when it finishes.

Usage:
  nmap -sV 192.168.1.1 | peon
  long_command | peon -s zug_zug
  long_command | peon --random

Passes stdin through to stdout, then plays a sound when EOF is reached
(i.e. the upstream command finished).
"""

PEON_VERSION = "1.1.0"

import argparse
import shutil
import subprocess
import sys
import os
import time

SOUND_DIR = os.path.expanduser("~/.local/share/peon/sounds")

# Default sound
DEFAULT_SOUND = os.path.join(SOUND_DIR, "PeonReady1.ogg")


def _is_wsl():
    """Detect if running under WSL/WSL2."""
    try:
        with open("/proc/version", "r") as f:
            return "microsoft" in f.read().lower()
    except Exception:
        return False


def _wsl_winpath(path):
    """Convert a Linux path to a Windows path via wslpath."""
    try:
        result = subprocess.run(
            ["wslpath", "-w", path],
            capture_output=True, text=True, timeout=5
        )
        return result.stdout.strip()
    except Exception:
        return path


def _play_wsl(sound_path):
    """Play sound on WSL2 by delegating to Windows."""
    powershell = shutil.which("powershell.exe") or shutil.which("pwsh.exe")
    if powershell and sound_path and os.path.exists(sound_path):
        winpath = _wsl_winpath(sound_path)
        try:
            subprocess.run(
                [powershell, "-NoProfile", "-Command",
                 f"(New-Object Media.SoundPlayer '{winpath}').PlaySync()"],
                capture_output=True, timeout=10
            )
            return True
        except Exception:
            pass
    if powershell:
        try:
            subprocess.run(
                [powershell, "-NoProfile", "-Command",
                 "[Console]::Beep(880, 300)"],
                capture_output=True, timeout=5
            )
            return True
        except Exception:
            pass
    sys.stderr.write("\a")
    sys.stderr.flush()
    return False


def play_sound(sound_path, volume=80):
    """Play a notification sound using whatever player is available."""
    if not sound_path or not os.path.exists(sound_path):
        sys.stderr.write("\a")
        sys.stderr.flush()
        return False

    is_wav = sound_path.lower().endswith(".wav")

    # Players that handle all formats (tried in order)
    players = {
        "ffplay": lambda p: [p, "-nodisp", "-autoexit", "-hide_banner",
                             "-loglevel", "quiet", sound_path],
        "mpv": lambda p: [p, "--no-video", "--really-quiet",
                          f"--volume={volume}", sound_path],
        "play": lambda p: [p, "-q", sound_path],  # SoX
    }

    # paplay/aplay only handle WAV natively
    if is_wav:
        players["paplay"] = lambda p: [p, sound_path]
        players["aplay"] = lambda p: [p, sound_path]

    for name, build_cmd in players.items():
        path = shutil.which(name)
        if path:
            try:
                subprocess.run(build_cmd(path), capture_output=True, timeout=10)
                return True
            except Exception:
                continue

    # WSL2 fallback
    if _is_wsl():
        return _play_wsl(sound_path)

    # macOS fallback
    afplay = shutil.which("afplay")
    if afplay:
        try:
            subprocess.run([afplay, sound_path], capture_output=True, timeout=10)
            return True
        except Exception:
            pass

    # Last resort: terminal bell
    sys.stderr.write("\a")
    sys.stderr.flush()
    return False


def resolve_sound(name):
    """Resolve a sound name to a file path.

    Accepts:
      - Full path: /path/to/sound.mp3
      - Name with ext: zug_zug.mp3
      - Name without ext: zug_zug (auto-finds .mp3/.ogg/.wav/.oga)
    """
    if os.path.isabs(name) and os.path.exists(name):
        return name

    # Try exact match in sound dir
    candidates = [
        os.path.join(SOUND_DIR, name),
        os.path.join(SOUND_DIR, name + ".ogg"),
        os.path.join(SOUND_DIR, name + ".mp3"),
        os.path.join(SOUND_DIR, name + ".wav"),
        os.path.join(SOUND_DIR, name + ".oga"),
    ]
    for c in candidates:
        if os.path.exists(c):
            return c

    return None


def list_sounds():
    """List all available sounds."""
    if not os.path.isdir(SOUND_DIR):
        print(f"No sounds directory: {SOUND_DIR}")
        return

    sounds = sorted([
        f for f in os.listdir(SOUND_DIR)
        if f.endswith((".mp3", ".wav", ".ogg", ".oga"))
    ])
    print(f"Available sounds ({len(sounds)} total):\n")
    for s in sounds:
        name = s.rsplit(".", 1)[0]
        print(f"  {name}")
    print(f"\nUsage: peon -s {sounds[0].rsplit('.', 1)[0] if sounds else 'sound_name'}")


def show_help():
    B = "\033[1m"
    G = "\033[32m"
    Y = "\033[33m"
    C = "\033[36m"
    D = "\033[2m"
    R = "\033[0m"

    # Count available sounds
    sound_count = 0
    default_mark = ""
    if os.path.isdir(SOUND_DIR):
        sound_count = len([f for f in os.listdir(SOUND_DIR)
                          if f.endswith((".mp3", ".wav", ".ogg", ".oga"))])
        if os.path.exists(DEFAULT_SOUND):
            default_mark = os.path.basename(DEFAULT_SOUND)

    print(f"""{B}{G}peon{R} v{PEON_VERSION} - get notified when your command finishes

{B}USAGE{R}
  {C}<command>{R} | {G}peon{R} [{Y}options{R}]

{B}DESCRIPTION{R}
  Pipe any command through {G}peon{R}. It passes output through normally,
  then plays a sound when the command finishes. Stop babysitting your terminal.

{B}EXAMPLES{R}
  {D}# Default sound (PeonReady1){R}
  nmap -sV 192.168.1.1 | {G}peon{R}

  {D}# Pick a specific sound{R}
  make build | {G}peon{R} {Y}-s zug_zug{R}
  cargo test | {G}peon{R} {Y}-s BattlecruiserOperational{R}

  {D}# Random sound from the library{R}
  docker build . | {G}peon{R} {Y}--random{R}

  {D}# Desktop notification + sound{R}
  npm install | {G}peon{R} {Y}--notify{R}

  {D}# Custom sound file{R}
  ./long_job.sh | {G}peon{R} {Y}--sound ~/bell.wav{R}

  {D}# Silent (no sound, just summary){R}
  rsync -av src/ dest/ | {G}peon{R} {Y}--no-sound{R}

{B}OPTIONS{R}
  {Y}-s, --sound NAME{R}     Play a specific sound (by name or path)
  {Y}-r, --random{R}         Play a random sound
  {Y}    --no-sound{R}       Skip sound, only print summary
  {Y}-n, --notify{R}         Send desktop notification (notify-send)
  {Y}-m, --message TEXT{R}   Custom notification message (with --notify)
  {Y}    --volume 0-100{R}   Sound volume (default: 80)
  {Y}-l, --list{R}           List all available sounds
  {Y}-v, --version{R}        Show version
  {Y}-h, --help{R}           Show this help

{B}SOUNDS{R} ({sound_count} available, default: {default_mark})
  Run {G}peon --list{R} to see all sounds.

{B}POPULAR SOUNDS{R}
  {C}PeonReady1{R}            Default peon ready sound
  {C}zug_zug{R}              Classic peon
  {C}goal_complete{R}        Mission accomplished
  {C}BattlecruiserOperational{R}  Terran battlecruiser
  {C}approve{R}              Peon approval
  {C}impressed{R}            Peon impressed
  {C}PeonWarcry1{R}          Orc peon war cry

{B}HOW IT WORKS{R}
  1. Pipes stdin to stdout (your output works normally)
  2. Detects EOF (upstream command finished)
  3. Plays the selected sound
  4. Prints elapsed time and output size to stderr

{B}REQUIREMENTS{R}
  {C}ffmpeg{R} (for sound) - sudo apt install ffmpeg
  {C}Python 3.6+{R} (usually pre-installed)

{D}Requires: ffmpeg (sudo apt install ffmpeg){R}
""")


def main():
    if "--version" in sys.argv or "-v" in sys.argv:
        print(f"peon v{PEON_VERSION}")
        sys.exit(0)

    if "--help" in sys.argv or "-h" in sys.argv:
        show_help()
        sys.exit(0)

    parser = argparse.ArgumentParser(
        description="Notify when a piped command finishes.",
        usage="<command> | peon [options]",
        add_help=False
    )
    parser.add_argument("--sound", "-s", default=None,
                        help="Sound name or path")
    parser.add_argument("--random", "-r", action="store_true",
                        help="Play a random sound")
    parser.add_argument("--no-sound", action="store_true",
                        help="Skip sound notification")
    parser.add_argument("--notify", "-n", action="store_true",
                        help="Send desktop notification")
    parser.add_argument("--message", "-m", default="command finished",
                        help="Custom notification message")
    parser.add_argument("--volume", type=int, default=80,
                        help="Sound volume 0-100 (default: 80)")
    parser.add_argument("--list", "-l", action="store_true",
                        help="List all available sounds")
    args = parser.parse_args()

    if args.list:
        list_sounds()
        sys.exit(0)

    start_time = time.time()

    # Pass through stdin to stdout
    bytes_written = 0
    try:
        while True:
            chunk = sys.stdin.buffer.read(65536)
            if not chunk:
                break
            sys.stdout.buffer.write(chunk)
            sys.stdout.buffer.flush()
            bytes_written += len(chunk)
    except BrokenPipeError:
        pass

    elapsed = time.time() - start_time

    # Determine which sound to play
    if not args.no_sound:
        sound_path = None

        if args.sound:
            # User specified a sound by name or path
            sound_path = resolve_sound(args.sound)
            if not sound_path:
                sys.stderr.write(f"⚠ Sound not found: {args.sound}\n")
                sys.stderr.write("  Run 'peon --list' to see available sounds\n")

        if not sound_path and args.random:
            import random
            if os.path.isdir(SOUND_DIR):
                sounds = [os.path.join(SOUND_DIR, f) for f in os.listdir(SOUND_DIR)
                          if f.endswith((".mp3", ".wav", ".ogg", ".oga"))]
                if sounds:
                    sound_path = random.choice(sounds)

        if not sound_path:
            sound_path = DEFAULT_SOUND

        if sound_path and os.path.exists(sound_path):
            basename = os.path.basename(sound_path)
            sys.stderr.write(f"🔔 {basename}\n")
        play_sound(sound_path, args.volume)

    # Desktop notification
    if args.notify:
        size_str = f"{bytes_written / 1024:.1f}KB" if bytes_written > 1024 else f"{bytes_written}B"
        elapsed_str = f"{elapsed:.1f}s" if elapsed < 60 else f"{elapsed / 60:.1f}m"
        full_msg = f"{args.message} | {elapsed_str}, {size_str} output"

        if shutil.which("notify-send"):
            try:
                subprocess.run(
                    ["notify-send", "-u", "normal", "-t", "5000", "peon", full_msg],
                    capture_output=True, timeout=5
                )
            except Exception:
                pass
        sys.stderr.write(f"🔔 {full_msg}\n")

    # Always print summary to stderr
    size_str = f"{bytes_written / 1024:.1f}KB" if bytes_written > 1024 else f"{bytes_written}B"
    elapsed_str = f"{elapsed:.1f}s" if elapsed < 60 else f"{elapsed / 60:.1f}m"
    sys.stderr.write(f"🔔 peon: done in {elapsed_str} ({size_str})\n")


if __name__ == "__main__":
    main()
