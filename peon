#!/usr/bin/env python3
"""
peon - get notified when your command finishes.

Usage:
  nmap -sV 192.168.1.1 && peon        standalone mode
  nmap -sV 192.168.1.1 | peon          pipe mode (passes output through)
  peon -s zug_zug                      just play a sound
"""

PEON_VERSION = "1.4.0"

import shutil
import subprocess
import sys
import os
import time

SOUND_DIR = os.path.expanduser("~/.local/share/peon/sounds")
DEFAULT_SOUND = os.path.join(SOUND_DIR, "peon-default.mp3")


def _is_wsl():
    try:
        with open("/proc/version", "r") as f:
            return "microsoft" in f.read().lower()
    except Exception:
        return False


def _wsl_winpath(path):
    try:
        result = subprocess.run(["wslpath", "-w", path], capture_output=True, text=True, timeout=5)
        return result.stdout.strip()
    except Exception:
        return path


def _play_wsl(sound_path):
    powershell = shutil.which("powershell.exe") or shutil.which("pwsh.exe")
    if powershell and sound_path and os.path.exists(sound_path):
        winpath = _wsl_winpath(sound_path)
        try:
            subprocess.run([powershell, "-NoProfile", "-Command",
                            f"(New-Object Media.SoundPlayer '{winpath}').PlaySync()"],
                           capture_output=True, timeout=10)
            return True
        except Exception:
            pass
    if powershell:
        try:
            subprocess.run([powershell, "-NoProfile", "-Command", "[Console]::Beep(880, 300)"],
                           capture_output=True, timeout=5)
            return True
        except Exception:
            pass
    sys.stderr.write("\a")
    sys.stderr.flush()
    return False


def play_sound(sound_path):
    if not sound_path or not os.path.exists(sound_path):
        sys.stderr.write("\a")
        sys.stderr.flush()
        return False

    is_wav = sound_path.lower().endswith(".wav")

    players = {
        "ffplay": lambda p: [p, "-nodisp", "-autoexit", "-hide_banner", "-loglevel", "quiet", sound_path],
        "mpv": lambda p: [p, "--no-video", "--really-quiet", sound_path],
        "play": lambda p: [p, "-q", sound_path],
    }

    if is_wav:
        players["paplay"] = lambda p: [p, sound_path]
        players["aplay"] = lambda p: [p, sound_path]

    for name, build_cmd in players.items():
        path = shutil.which(name)
        if path:
            try:
                subprocess.run(build_cmd(path), capture_output=True, timeout=10)
                return True
            except Exception:
                continue

    if _is_wsl():
        return _play_wsl(sound_path)

    afplay = shutil.which("afplay")
    if afplay:
        try:
            subprocess.run([afplay, sound_path], capture_output=True, timeout=10)
            return True
        except Exception:
            pass

    sys.stderr.write("\a")
    sys.stderr.flush()
    return False


def resolve_sound(name):
    if os.path.isabs(name) and os.path.exists(name):
        return name
    for ext in ("", ".ogg", ".mp3", ".wav", ".oga"):
        candidate = os.path.join(SOUND_DIR, name + ext)
        if os.path.exists(candidate):
            return candidate
    return None


def list_sounds():
    if not os.path.isdir(SOUND_DIR):
        print(f"No sounds directory: {SOUND_DIR}")
        return
    sounds = sorted(f for f in os.listdir(SOUND_DIR) if f.endswith((".mp3", ".wav", ".ogg", ".oga")))
    print(f"Available sounds ({len(sounds)} total):\n")
    for s in sounds:
        print(f"  {s.rsplit('.', 1)[0]}")
    if sounds:
        print(f"\nUsage: peon -s {sounds[0].rsplit('.', 1)[0]}")


def download_sounds():
    import urllib.request
    import json

    API_URL = "https://api.github.com/repos/MELTzx/peon/contents/sounds"
    print("Downloading full sound library...")
    try:
        req = urllib.request.Request(API_URL, headers={"User-Agent": "peon"})
        with urllib.request.urlopen(req) as resp:
            data = json.loads(resp.read())
            sounds = [f for f in data if f["name"].endswith((".mp3", ".wav", ".ogg", ".oga"))]
            sounds = [f for f in sounds if f["name"] != "peon-default.mp3"]
            print(f"  Downloading {len(sounds)} sounds (~4.7MB)...")
            ok = 0
            for s in sounds:
                out = os.path.join(SOUND_DIR, s["name"])
                urllib.request.urlretrieve(s["download_url"], out)
                ok += 1
                if ok % 20 == 0:
                    print(f"  {ok}/{len(sounds)}...")
            print(f"  Done! {ok + 1} sounds total.")
            print(f"  Run 'peon --list' to see all sounds.")
    except Exception as e:
        print(f"  Failed: {e}")
        sys.exit(1)


def show_help():
    B = "\033[1m"
    G = "\033[32m"
    Y = "\033[33m"
    C = "\033[36m"
    D = "\033[2m"
    R = "\033[0m"

    print(f"""{B}{G}peon{R} v{PEON_VERSION} - get notified when your command finishes

{B}USAGE{R}
  {C}<command>{R} && {G}peon{R}         play sound when command succeeds
  {C}<command>{R} | {G}peon{R}          pipe mode: pass output through, play sound when done
  {G}peon{R}                        just play the default sound

{B}EXAMPLES{R}
  {D}# After a command finishes{R}
  nmap -sV 192.168.1.1 && {G}peon{R}

  {D}# Piped (output passes through){R}
  nmap -sV 192.168.1.1 | {G}peon{R}

  {D}# Pick a specific sound{R}
  make build && {G}peon{R} {Y}-s zug_zug{R}

  {D}# Random sound{R}
  docker build . | {G}peon{R} {Y}--random{R}

  {D}# Over SSH{R}
  ssh server "make build" && {G}peon{R}

{B}OPTIONS{R}
  {Y}-s, --sound NAME{R}       Play a specific sound (by name or path)
  {Y}-r, --random{R}           Play a random sound
  {Y}-l, --list{R}             List installed sounds
  {Y}    --download-sounds{R}  Download all 159 sounds (~4.7MB)
  {Y}-v, --version{R}          Show version
  {Y}-h, --help{R}             Show this help

{B}POPULAR SOUNDS{R}
  {C}peon-default{R}            Default (always installed)
  {C}PeonReady1{R}             WC3 Peon ready
  {C}zug_zug{R}               Classic peon
  {C}goal_complete{R}          Mission accomplished
  {C}BattlecruiserOperational{R}  Starcraft Terran
  {C}PeonWarcry1{R}            Orc war cry

  Run {G}peon --download-sounds{R} to get all 159 sounds.

{B}REQUIRES{R}
  {C}ffmpeg{R} - sudo apt install ffmpeg
""")


def main():
    if "--version" in sys.argv or "-v" in sys.argv:
        print(f"peon v{PEON_VERSION}")
        sys.exit(0)

    if "--help" in sys.argv or "-h" in sys.argv:
        show_help()
        sys.exit(0)

    # Parse args
    sound_name = None
    do_random = False

    i = 1
    while i < len(sys.argv):
        a = sys.argv[i]
        if a in ("-s", "--sound") and i + 1 < len(sys.argv):
            sound_name = sys.argv[i + 1]
            i += 2
        elif a in ("-r", "--random"):
            do_random = True
            i += 1
        elif a in ("-l", "--list"):
            list_sounds()
            sys.exit(0)
        elif a == "--download-sounds":
            download_sounds()
            sys.exit(0)
        else:
            sys.stderr.write(f"Unknown option: {a}\n")
            sys.exit(1)

    start_time = time.time()

    # Check if stdin has data (pipe mode) or standalone mode
    has_stdin = not sys.stdin.isatty()
    bytes_written = 0

    if has_stdin:
        try:
            while True:
                chunk = sys.stdin.buffer.read(65536)
                if not chunk:
                    break
                sys.stdout.buffer.write(chunk)
                sys.stdout.buffer.flush()
                bytes_written += len(chunk)
        except BrokenPipeError:
            pass

    elapsed = time.time() - start_time

    # Pick sound
    sound_path = None
    if sound_name:
        sound_path = resolve_sound(sound_name)
        if not sound_path:
            sys.stderr.write(f"Sound not found: {sound_name}\n")
            sys.stderr.write("Run 'peon --list' to see available sounds\n")
    if not sound_path and do_random:
        import random
        if os.path.isdir(SOUND_DIR):
            sounds = [os.path.join(SOUND_DIR, f) for f in os.listdir(SOUND_DIR)
                      if f.endswith((".mp3", ".wav", ".ogg", ".oga"))]
            if sounds:
                sound_path = random.choice(sounds)
    if not sound_path:
        sound_path = DEFAULT_SOUND

    if sound_path and os.path.exists(sound_path):
        sys.stderr.write(f"🔔 {os.path.basename(sound_path)}\n")
    play_sound(sound_path)

    if has_stdin:
        size_str = f"{bytes_written / 1024:.1f}KB" if bytes_written > 1024 else f"{bytes_written}B"
        elapsed_str = f"{elapsed:.1f}s" if elapsed < 60 else f"{elapsed / 60:.1f}m"
        sys.stderr.write(f"peon: done in {elapsed_str} ({size_str})\n")


if __name__ == "__main__":
    main()
